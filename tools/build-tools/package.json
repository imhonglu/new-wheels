{
  "name": "@imhonglu/build-tools",
  "version": "1.0.8",
  "description": "Build tools for the project.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imhonglu/new-wheels.git",
    "directory": "tools/build-tools"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "esm-to-cjs": "./esm-to-cjs.cli.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [],
  "author": "imhonglu <anonymouser.unknown@gmail.com>",
  "license": "MIT",
  "sideEffects": false,
  "peerDependencies": {
    "esbuild": "catalog:",
    "tslib": "catalog:",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@imhonglu/configs": "workspace:*"
  },
  "dependencies": {
    "@imhonglu/toolkit": "workspace:*"
  }
}
