#!/usr/bin/env sh
# cspell:ignore ACMR

# pre-push
#
# 푸시 전에 변경된 파일과 관련된 테스트를 실행합니다.
# push되는 commit 범위의 코드 파일을 대상으로 Vitest related 검사를 실행합니다.
#
# 참고: https://git-scm.com/book/ko/v2/Git맞춤-Git-Hooks

set -eu

remote_name=$1
zero_sha=0000000000000000000000000000000000000000
files=""

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "$zero_sha" ]; then
    continue
  fi

  if [ "$remote_sha" = "$zero_sha" ]; then
    remote_head=$(git symbolic-ref --quiet --short "refs/remotes/$remote_name/HEAD" || true)
    base=$(git merge-base "$local_sha" "$remote_head" 2>/dev/null || true)

    if [ -z "$base" ]; then
      base=$(git rev-list --max-parents=0 "$local_sha" | tail -n 1)
    fi
  else
    base=$remote_sha
  fi

  changed=$(git diff --name-only --diff-filter=ACMR "$base" "$local_sha")
  files=$(printf '%s\n%s\n' "$files" "$changed" | sed '/^$/d' | sort -u)
done

# 검사할 파일이 없으면 종료합니다.
if [ -z "$files" ]; then
  exit 0
fi

# 문서나 changeset만 변경된 경우 테스트를 생략합니다.
code_files=$(printf '%s\n' "$files" | grep -E '\.(c|m)?[jt]sx?$' || true)

if [ -z "$code_files" ]; then
  exit 0
fi

# CI와 동일하게 자동 생성 테스트를 제외하고 관련 테스트를 실행합니다.
pnpm exec vitest related --run --passWithNoTests --exclude "src/generated-tests/**" $code_files
