#!/usr/bin/env sh
# cspell:ignore ACMR

# pre-commit
#
# 커밋 전에 스테이지된 파일을 검사합니다.
# CSpell 맞춤법 검사와 Biome 검사를 순서대로 실행합니다.
#
# 참고: https://git-scm.com/book/ko/v2/Git맞춤-Git-Hooks

set -eu

# 스테이지된 파일 목록을 조회합니다.
files=$(git diff --cached --name-only --diff-filter=ACMR) # added, copied, modified, or renamed

# 검사할 파일이 없으면 종료합니다.
if [ -z "$files" ]; then
  exit 0
fi

# 검사 도구를 실행합니다.
pnpm exec cspell --no-must-find-files --files $files
pnpm exec biome check --no-errors-on-unmatched $files

if printf '%s\n' "$files" | grep -q '\.md$'; then
  pnpm run check:docs
fi
